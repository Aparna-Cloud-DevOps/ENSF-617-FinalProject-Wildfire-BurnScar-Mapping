    "---\n",
    "## 3. Training Dynamics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "aa599dba",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1560x540 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Convergence summary:\n",
      "  UNet            : best epoch = 20,  val mIoU = 0.6664\n",
      "  ResUNet         : best epoch =  8,  val mIoU = 0.6938\n",
      "  AttentionUNet   : best epoch = 18,  val mIoU = 0.6879\n",
      "  UNet++          : best epoch = 20,  val mIoU = 0.6900\n"
     ]
    }
   ],
   "source": [
    "# Two-panel figure: (left) train vs. val loss, (right) val mIoU over epochs.\n",
    "# Convention: dashed line = training split, solid line = validation split.\n",
    "# A dotted vertical line and filled scatter marker denote each model's best\n",
    "# checkpoint (selected by EMA-smoothed val mIoU, not raw val mIoU).\n",
    "fig, axes = plt.subplots(1, 2, figsize=(13, 4.5))\n",
    "\n",
    "for mkey, mlbl, col in zip(MODEL_ORDER, MODEL_LABELS, COLORS):\n",
    "    hist = all_res[mkey]['history']          # dict of lists: train_loss, val_loss, val_miou\n",
    "    epochs = range(1, len(hist['train_loss']) + 1)\n",
    "\n",
    "    # Loss curves: dashed for train (lower variance), solid for val\n",
    "    axes[0].plot(epochs, hist['train_loss'], color=col, lw=1.8,\n",
    "                 linestyle='--', alpha=0.6, label=f'{mlbl} train')\n",
    "    axes[0].plot(epochs, hist['val_loss'],   color=col, lw=2.0,\n",
    "                 label=f'{mlbl} val')\n",
    "\n",
    "    # Validation mIoU curve with best-epoch annotation\n",
    "    axes[1].plot(epochs, hist['val_miou'],   color=col, lw=2.0, label=mlbl)\n",
    "\n",
    "    # best_epoch is 1-indexed; index into val_miou list requires be-1\n",
    "    be = all_res[mkey]['best_epoch']\n",
    "    axes[1].axvline(be, color=col, lw=1.0, linestyle=':', alpha=0.7)\n",
    "    axes[1].scatter([be], [hist['val_miou'][be-1]], color=col,\n",
    "                    s=60, zorder=5)  # filled circle on top of line\n",
    "\n",
    "axes[0].set_xlabel('Epoch'); axes[0].set_ylabel('FocalDiceLoss')\n",
    "axes[0].set_title('Training & Validation Loss')\n",
    "axes[0].legend(fontsize=8, ncol=2)  # 2-column legend to save vertical space\n",
    "\n",
    "axes[1].set_xlabel('Epoch'); axes[1].set_ylabel('Validation mIoU')\n",
    "axes[1].set_title('Validation mIoU per Epoch (\\u25cf = best checkpoint)')\n",
    "axes[1].legend(fontsize=9)\n",
    "\n",
    "plt.suptitle('Fig. 2 \\u2014 Training Dynamics for All Four Architectures',\n",
    "             fontsize=12, y=1.01)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Print convergence statistics for each model\n",
    "print('Convergence summary:')\n",
    "for mkey, mlbl in zip(MODEL_ORDER, MODEL_LABELS):\n",
    "    be = all_res[mkey]['best_epoch']\n",
    "    bv = all_res[mkey]['val_miou']\n",
    "    print(f'  {mlbl:16s}: best epoch = {be:2d},  val mIoU = {bv:.4f}')\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "1cead0dd",
   "metadata": {},
   "source": [
    "**Analysis:**  \n",
    "ResUNet reaches its best checkpoint at **epoch 8** — 12 epochs before UNet. Pre-activation residual units stabilise gradient flow across all encoder depths, explaining the steeper initial loss descent. AttentionUNet converges latest (epoch 18), suggesting attention gates require more gradient updates to learn meaningful spectral gating on this dataset. UNet++ and UNet both plateau at epoch 20, consistent with vanilla concatenative skip connections providing no gradient acceleration."
   ]
  },
