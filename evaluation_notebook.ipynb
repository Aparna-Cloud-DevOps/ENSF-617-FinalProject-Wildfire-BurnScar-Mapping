    "all_labels = MODEL_LABELS + ['dNBR Threshold', 'Random Forest']\n",
    "all_miou   = [all_res[m]['test']['mean_iou'] for m in MODEL_ORDER] + \\\n",
    "             [base_m['dnbr_threshold']['test']['mean_iou'],\n",
    "              base_m['random_forest']['test']['mean_iou']]\n",
    "all_mdice  = [all_res[m]['test']['mean_dice'] for m in MODEL_ORDER] + \\\n",
    "             [base_m['dnbr_threshold']['test']['mean_dice'],\n",
    "              base_m['random_forest']['test']['mean_dice']]\n",
    "\n",
    "# Grey tones for baselines to distinguish from the coloured deep models\n",
    "bar_colors = COLORS + ['#95a5a6', '#7f8c8d']\n",
    "\n",
    "x  = np.arange(len(all_labels))  # one tick position per model/baseline\n",
    "w  = 0.35                         # bar width; two bars per position offset by ±w/2\n",
    "fig, ax = plt.subplots(figsize=(11, 5))\n",
    "\n",
    "# Left bar = mIoU (full opacity); right bar = mDice (50% opacity, coloured border)\n",
    "b1 = ax.bar(x - w/2, all_miou,  w, label='mIoU',  color=bar_colors, alpha=0.85)\n",
    "b2 = ax.bar(x + w/2, all_mdice, w, label='mDice', color=bar_colors, alpha=0.50,\n",
    "            edgecolor=[c for c in bar_colors], linewidth=1.5)\n",
    "# Annotate all bars with their numeric values\n",
    "for bar, val in zip(list(b1)+list(b2), all_miou+all_mdice):\n",
    "    ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.005,\n",
    "            f'{val:.3f}', ha='center', va='bottom', fontsize=8)\n",
