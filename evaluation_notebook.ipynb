    "ax.set_ylabel('Test mIoU'); ax.set_ylim(0, 0.75)\n",
    "ax.set_title('Fig. 7 \\u2014 Ablation Study: Impact of Key Design Choices', fontsize=12)\n",
    "ax.tick_params(axis='x', labelsize=9)\n",
    "ax.legend(fontsize=9)\n",
    "plt.xticks(rotation=10, ha='right')\n",
