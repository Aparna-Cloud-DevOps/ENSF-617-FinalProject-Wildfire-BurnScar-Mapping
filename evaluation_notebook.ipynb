   "source": [
    "# Load per-fire metrics and truncate fire IDs to 8 chars for axis readability.\n",
    "# Full fire_id format: '{COUNTRY}_{EVENT_ID}_{YEAR}'; short form preserves\n",
    "# enough information to identify fires in cross-reference with MTBS/NBAC records.\n",
    "df_pf = pd.DataFrame(pfire_m)\n",
    "df_pf['fire_short'] = df_pf['fire_id'].str[:8]\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(13, 5))\n",
    "\n",
    "# Left panel: horizontal bar chart of per-fire mIoU sorted by fire_id order\n",
    "bars = axes[0].barh(df_pf['fire_short'], df_pf['mean_iou'],\n",
    "                     color=COLORS[1], alpha=0.85, edgecolor='white')\n",
    "# Reference line at the mean mIoU across all test fires\n",
    "axes[0].axvline(df_pf['mean_iou'].mean(), color='grey', lw=1.5,\n",
    "                linestyle='--', label=f'Mean = {df_pf[\"mean_iou\"].mean():.3f}')\n",
    "axes[0].set_xlabel('mIoU')\n",
    "axes[0].set_title('Per-Fire mIoU (ResUNet, Test Set)')\n",
    "axes[0].legend(fontsize=9)\n",
    "# Annotate each bar with its numeric IoU value (offset 0.005 from bar tip)\n",
    "for bar, val in zip(bars, df_pf['mean_iou']):\n",
    "    axes[0].text(val + 0.005, bar.get_y() + bar.get_height()/2,\n",
    "                 f'{val:.3f}', va='center', fontsize=9)\n",
    "\n",
