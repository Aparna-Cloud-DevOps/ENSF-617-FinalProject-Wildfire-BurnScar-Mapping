    "    'axes.titlesize': 12,\n",
    "    'axes.labelsize': 11,\n",
    "    'figure.dpi':   120,          # high-DPI for crisp notebook rendering\n",
    "    'axes.spines.top':    False,  # suppress top spine\n",
    "    'axes.spines.right':  False,  # suppress right spine\n",
    "})\n",
    "\n",
    "# Project root and key output directories\n",
    "BASE    = '/home/aparna.ayyalasomayaj/wildfire_burn_scar_mapping'\n",
    "RES_DIR = f'{BASE}/outputs/sentinel2_results_v2'  # main model outputs\n",
    "FIG_DIR = f'{RES_DIR}/figures'                    # pre-rendered figure PNGs\n",
    "ABL_DIR = f'{BASE}/outputs/ablation'              # ablation experiment outputs\n",
    "\n",
    "# ── Load all metrics ─────────────────────────────────────────────────────────\n",
    "# all_results.json: nested dict {model_key -> {train, val, test, history, ...}}\n",
    "# unet_metrics.json: UNet saved separately (added later in pipeline)\n",
    "# baseline_metrics.json: dNBR threshold and Random Forest results\n",
    "# per_fire_metrics.json: per-fire breakdown for the ResUNet (best model)\n",
    "with open(f'{RES_DIR}/all_results.json')      as f: all_res  = json.load(f)\n",
    "with open(f'{RES_DIR}/unet_metrics.json')     as f: unet_m   = json.load(f)\n",
    "with open(f'{RES_DIR}/baseline_metrics.json') as f: base_m   = json.load(f)\n",
    "with open(f'{RES_DIR}/per_fire_metrics.json') as f: pfire_m  = json.load(f)\n",
    "with open(f'{ABL_DIR}/ablation_summary.json') as f: ablation = json.load(f)\n",
    "\n",
    "# Merge UNet results into all_res so downstream cells use a unified dict\n",
    "all_res['unet'] = unet_m\n",
    "\n",
    "# Severity class names (MTBS 4-class scheme) and per-model display labels/colours\n",
    "CLASS_NAMES  = ['Unburned/Low', 'Moderate', 'High', 'Very High']\n",
    "MODEL_ORDER  = ['unet', 'resunet', 'attention', 'unetpp']   # dict key order\n",
    "MODEL_LABELS = ['UNet', 'ResUNet', 'AttentionUNet', 'UNet++'] # display names\n",
    "COLORS       = ['#3498db', '#e74c3c', '#2ecc71', '#9b59b6']  # one colour per model\n",
    "SEV_COLORS   = ['#2ecc71', '#f39c12', '#e74c3c', '#9b59b6']  # one colour per severity class\n",
    "\n",
    "print('Metrics loaded successfully.')\n",
    "print(f'Models available: {list(all_res.keys())}')\n"
   ]
