   "source": [
    "# Retrieve the full-model mIoU from all_res to compute relative deltas.\n",
    "# All ablation variants use identical hyperparameters (lr, batch, epochs) to\n",
    "# isolate the effect of a single design choice at a time.\n",
    "full_miou = all_res['resunet']['test']['mean_iou']\n",
    "\n",
    "# Start the row list with the full-model baseline row (delta = 0 by definition)\n",
    "abl_rows = [\n",
    "    {'ID': 'Full',  'Configuration': '7-ch + Augment + FocalDice',\n",
    "     'mIoU': full_miou, 'Delta': '\\u2014'},\n",
    "]\n",
    "# Ablation variant labels matching keys in ablation_summary.json:\n",
    "#   A — remove spectral indices (NBR_pre, dNBR), leaving 5 Sentinel-2 bands\n",
    "#   B — disable data augmentation (random flip/rotate/colour jitter)\n",
    "#   C — replace FocalDiceLoss with standard CrossEntropyLoss\n",
    "abl_configs = {\n",
    "    'A': 'No spectral indices (5-ch)',\n",
    "    'B': 'No augmentation (7-ch)',\n",
    "    'C': 'CrossEntropy loss (7-ch)',\n",
    "}\n",
    "for key, cfg in abl_configs.items():\n",
    "    miou = ablation[key]['test']['mean_iou']\n",
    "    # Relative delta: how much mIoU drops compared to the full model (negative = worse)\n",
    "    delta = (miou - full_miou) / full_miou * 100\n",
    "    abl_rows.append({'ID': key, 'Configuration': cfg,\n",
    "                     'mIoU': round(miou, 4),\n",
    "                     'Delta': f'{delta:+.1f}%'})\n",
    "\n",
    "df_abl = pd.DataFrame(abl_rows).set_index('ID')\n",
    "print('Ablation Study \\u2014 ResUNet (Test Set)')\n",
    "print('=' * 55)\n",
    "display(df_abl)\n",
    "\n",
    "# Bar chart: green for the full model, red for each ablation to highlight regression\n",
    "fig, ax = plt.subplots(figsize=(8, 4))\n",
    "labels   = [r['Configuration'] for r in abl_rows]\n",
    "mious    = [r['mIoU'] for r in abl_rows]\n",
    "bar_cols = ['#2ecc71'] + ['#e74c3c'] * 3  # green = full; red = ablation\n",
