   "source": [
    "# Load and display pre-rendered Precision-Recall curves.\n",
    "# PR curves are preferred over ROC curves for imbalanced multi-class problems:\n",
    "# ROC-AUC can appear optimistic when the negative class dominates, whereas\n",
    "# PR-AUC directly reflects the model's ability to retrieve minority classes.\n",
    "img = imread(f'{FIG_DIR}/pr_curves.png')\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "ax.imshow(img)\n",
    "ax.axis('off')\n",
    "ax.set_title(\n",
    "    'Fig. 5 \\u2014 Precision\\u2013Recall Curves per Severity Class (All Models, Test Set)',\n",
    "    fontsize=12, pad=8)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Print per-class PR-AUC for the best model to quantify the difficulty gradient\n",
    "print('PR-AUC per class \\u2014 ResUNet (best model):')\n",
    "t = all_res['resunet']['test']\n",
